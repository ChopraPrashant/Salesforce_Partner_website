---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import Icon from "../components/Icon.astro";
import { company } from "../data/site";

const contactCards = [
  {
    icon: "mail",
    title: "Email us",
    value: company.email,
    href: `mailto:${company.email}`,
  },
  {
    icon: "phone",
    title: "Call us",
    value: company.phone,
    href: `tel:${company.phone.replace(/\s/g, "")}`,
  },
  {
    icon: "pin",
    title: "Visit us",
    value: company.address.full,
    href: "#map",
  },
];

const mapQuery = encodeURIComponent(company.address.full);
---

<Layout
  title="Contact"
  description="Get in touch with Cubitous Infotech for Salesforce consulting, implementation, training, and support. Based in Ambli, Ahmedabad."
>
  <PageHero
    eyebrow="Contact Us"
    title="Let's talk about your Salesforce goals"
    subtitle="Whether you're starting a new project, need support, or want to join our team — we'd love to hear from you."
    breadcrumb={[{ label: "Home", href: "/" }, { label: "Contact" }]}
  />

  <section class="container-page py-14 sm:py-20">
    <div class="grid lg:grid-cols-5 gap-10 lg:gap-14">
      <!-- Info -->
      <div class="lg:col-span-2">
        <h2 class="text-2xl font-extrabold text-navy tracking-tight">Get in touch</h2>
        <p class="mt-3 text-slate-600 leading-relaxed">
          Reach out through any channel below or send us a message. We typically
          respond within one business day.
        </p>

        <div class="mt-8 space-y-4">
          {
            contactCards.map((c) => (
              <a
                href={c.href}
                class="flex items-start gap-4 rounded-2xl bg-white p-5 ring-1 ring-slate-100 shadow-sm transition hover:ring-brand-200 hover:shadow-md"
              >
                <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600">
                  <Icon name={c.icon} class="w-5 h-5" />
                </span>
                <span>
                  <span class="block text-sm font-bold text-navy">{c.title}</span>
                  <span class="block text-sm text-slate-600 break-words">{c.value}</span>
                </span>
              </a>
            ))
          }
        </div>

        <div class="mt-8 rounded-2xl bg-navy-gradient p-6 text-white">
          <h3 class="font-bold">Office hours</h3>
          <p class="mt-2 text-sm text-brand-100/80">
            Monday – Friday: 10:00 AM – 7:00 PM IST
          </p>
          <p class="text-sm text-brand-100/80">Saturday – Sunday: Closed</p>
        </div>
      </div>

      <!-- Form -->
      <div class="lg:col-span-3">
        <form
          id="contact-form"
          class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-100 sm:p-8"
          data-recipient={company.email}
          novalidate
        >
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="contact-name" class="mb-1.5 block text-sm font-semibold text-navy">
                Full name *
              </label>
              <input
                id="contact-name"
                name="name"
                type="text"
                required
                class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-brand-500 focus:ring-2 focus:ring-brand-100"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="contact-email" class="mb-1.5 block text-sm font-semibold text-navy">
                Email *
              </label>
              <input
                id="contact-email"
                name="email"
                type="email"
                required
                class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-brand-500 focus:ring-2 focus:ring-brand-100"
                placeholder="you@company.com"
              />
            </div>
            <div>
              <label for="contact-phone" class="mb-1.5 block text-sm font-semibold text-navy">
                Phone
              </label>
              <input
                id="contact-phone"
                name="phone"
                type="tel"
                class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-brand-500 focus:ring-2 focus:ring-brand-100"
                placeholder="+91 ..."
              />
            </div>
            <div>
              <label for="contact-company" class="mb-1.5 block text-sm font-semibold text-navy">
                Company
              </label>
              <input
                id="contact-company"
                name="company"
                type="text"
                class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-brand-500 focus:ring-2 focus:ring-brand-100"
                placeholder="Company name"
              />
            </div>
          </div>

          <div class="mt-5">
            <label for="contact-service" class="mb-1.5 block text-sm font-semibold text-navy">
              Service you're interested in
            </label>
            <select
              id="contact-service"
              name="service"
              class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100"
            >
              <option value="">Select a service</option>
              <option>Salesforce CRM Implementation</option>
              <option>Sales Cloud</option>
              <option>Service Cloud</option>
              <option>Revenue Cloud Advanced (RCA)</option>
              <option>Conga CPQ</option>
              <option>Conga CLM</option>
              <option>Experience Cloud</option>
              <option>Integration & Data Migration</option>
              <option>Agentforce & Einstein AI</option>
              <option>Managed Services & Support</option>
              <option>Training & Internship</option>
              <option>Other</option>
            </select>
          </div>

          <div class="mt-5">
            <label for="contact-message" class="mb-1.5 block text-sm font-semibold text-navy">
              Message *
            </label>
            <textarea
              id="contact-message"
              name="message"
              rows="5"
              required
              class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-brand-500 focus:ring-2 focus:ring-brand-100"
              placeholder="Tell us about your project, timeline, or question..."
            ></textarea>
          </div>

          <p id="contact-form-error" class="mt-4 hidden rounded-lg bg-red-50 px-4 py-3 text-sm text-red-600"></p>

          <button
            type="submit"
            class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-full bg-brand-gradient px-7 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-600/25 transition hover:-translate-y-0.5 hover:shadow-xl sm:w-auto"
          >
            Send Message
          </button>
        </form>
        <p class="mt-4 text-xs text-slate-400">
          By submitting, you agree to be contacted about your enquiry. We respect
          your privacy — see our <a href="/privacy" class="underline hover:text-brand-600">Privacy Policy</a>.
        </p>
      </div>
    </div>
  </section>

  <script>
    const contactForm = document.getElementById("contact-form");
    const contactError = document.getElementById("contact-form-error");

    const invalidFieldStyle = {
      borderColor: "#f87171",
      boxShadow: "0 0 0 2px rgb(254 226 226)",
    };
    const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const phonePattern = /^\+?[\d\s().-]{7,20}$/;

    const setFieldInvalid = (field) => {
      if (!(field instanceof HTMLElement)) return;
      field.setAttribute("aria-invalid", "true");
      field.style.borderColor = invalidFieldStyle.borderColor;
      field.style.boxShadow = invalidFieldStyle.boxShadow;
    };

    const clearFieldInvalid = (field) => {
      if (!(field instanceof HTMLElement)) return;
      field.removeAttribute("aria-invalid");
      field.style.borderColor = "";
      field.style.boxShadow = "";
    };

    const getFieldValue = (field) => {
      if (field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement || field instanceof HTMLSelectElement) {
        return field.value.trim();
      }
      return "";
    };

    const isValidPhone = (value) => {
      if (!value) return true;
      const digits = value.replace(/\D/g, "");
      return phonePattern.test(value) && digits.length >= 7 && digits.length <= 15;
    };

    const validateContactForm = (form) => {
      let firstInvalid = null;

      form.querySelectorAll("input, textarea, select").forEach(clearFieldInvalid);

      form.querySelectorAll("[required]").forEach((field) => {
        if (!getFieldValue(field)) {
          setFieldInvalid(field);
          firstInvalid ??= field;
        }
      });

      const email = form.querySelector('input[type="email"]');
      if (email instanceof HTMLInputElement && email.value.trim() && !emailPattern.test(email.value.trim())) {
        setFieldInvalid(email);
        firstInvalid ??= email;
      }

      const phone = form.querySelector('input[type="tel"]');
      if (phone instanceof HTMLInputElement && !isValidPhone(phone.value.trim())) {
        setFieldInvalid(phone);
        firstInvalid ??= phone;
      }

      return firstInvalid;
    };

    contactForm?.querySelectorAll("input, textarea, select").forEach((field) => {
      field.addEventListener("input", () => clearFieldInvalid(field));
      field.addEventListener("change", () => clearFieldInvalid(field));
    });

    contactForm?.addEventListener("submit", (event) => {
      event.preventDefault();

      const form = event.currentTarget;
      if (!(form instanceof HTMLFormElement)) return;

      const errorBox = contactError instanceof HTMLElement ? contactError : null;
      const formData = new FormData(form);
      const recipient = form.dataset.recipient || "contact@cubitous.com";

      const showError = (message) => {
        if (!errorBox) return;
        errorBox.textContent = message;
        errorBox.classList.remove("hidden");
      };

      errorBox?.classList.add("hidden");

      const firstInvalid = validateContactForm(form);
      if (firstInvalid instanceof HTMLElement) {
        showError("Please fill all required fields and enter a valid email/phone number.");
        firstInvalid.focus();
        return;
      }

      const subject = encodeURIComponent(`Website enquiry: ${formData.get("service") || "General"}`);
      const body = encodeURIComponent(
        [
          `Name: ${formData.get("name")}`,
          `Email: ${formData.get("email")}`,
          `Phone: ${formData.get("phone") || "-"}`,
          `Company: ${formData.get("company") || "-"}`,
          `Service: ${formData.get("service") || "-"}`,
          "",
          "Message:",
          formData.get("message"),
        ].join("\n"),
      );

      window.location.href = `mailto:${recipient}?subject=${subject}&body=${body}`;
    });
  </script>

  <!-- MAP -->
  <section id="map" class="pb-16 sm:pb-24 scroll-mt-24">
    <div class="container-page">
      <div class="overflow-hidden rounded-3xl ring-1 ring-slate-100 shadow-sm">
        <iframe
          title="Cubitous Infotech location map"
          src={`https://www.google.com/maps?q=${mapQuery}&output=embed`}
          width="100%"
          height="420"
          style="border:0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="block w-full"
        ></iframe>
      </div>
    </div>
  </section>
</Layout>
