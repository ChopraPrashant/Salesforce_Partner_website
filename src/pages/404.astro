---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
---

<Layout title="Page not found">
  <section class="relative overflow-hidden bg-navy-gradient text-white">
    <div class="absolute inset-0 bg-grid opacity-50"></div>
    <div class="relative container-page py-28 sm:py-36 text-center">
      <p class="text-7xl sm:text-8xl font-extrabold text-gradient">404</p>
      <h1 class="mt-4 text-3xl sm:text-4xl font-extrabold tracking-tight">
        Page not found
      </h1>
      <p class="mt-4 max-w-md mx-auto text-brand-100/80">
        The page you're looking for doesn't exist or may have moved. Let's get
        you back on track.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row justify-center gap-3">
        <Button href="/" variant="white" size="lg" icon="arrow">Back to home</Button>
        <Button
          href="/services"
          size="lg"
          class="!bg-white/10 !text-white hover:!bg-white/20 border border-white/20"
        >
          Browse services
        </Button>
      </div>
    </div>
  </section>
</Layout>
