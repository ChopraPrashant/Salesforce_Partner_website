---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import CTASection from "../components/CTASection.astro";
import realOrgLearningImage from "../Images/Real org based learning.png";
import { trainingTracks, trainingFeatures, process } from "../data/site";

const steps = [
  { n: "01", t: "Apply", d: "Submit your details and tell us your goals." },
  { n: "02", t: "Learn", d: "Live, mentor-led sessions on real Salesforce orgs." },
  { n: "03", t: "Build", d: "Work on hands-on projects and an internship." },
  { n: "04", t: "Get certified & placed", d: "Exam prep, interview support, and placement assistance." },
];
---

<Layout
  title="Training & Internships"
  description="Become a job-ready Salesforce professional with Cubitous Infotech's mentor-led training and internship programs — Admin, Developer, and CPQ tracks."
>
  <PageHero
    eyebrow="Training & Internships"
    title="Become a Salesforce-Ready Developer"
    subtitle="Mentor-led training and real-project internships that turn freshers and career-switchers into confident, job-ready Salesforce professionals."
    breadcrumb={[{ label: "Home", href: "/" }, { label: "Training" }]}
  >
    <div class="mt-8">
      <Button href="/contact" variant="white" size="lg" icon="arrow">
        Enroll / Enquire now
      </Button>
    </div>
  </PageHero>

  <!-- TRACKS -->
  <section class="container-page pt-10 sm:pt-14 pb-10 sm:pb-14">
    <SectionHeading
      eyebrow="Programs"
      title="Choose your learning track"
      subtitle="Structured programs designed around what employers actually need."
    />
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        trainingTracks.map((t) => (
          <div class="reveal card-lift flex flex-col rounded-2xl bg-white p-7 ring-1 ring-slate-100 shadow-sm">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-brand-gradient text-white">
              <Icon name={t.icon} class="w-6 h-6" />
            </span>
            <h3 class="mt-5 text-lg font-bold text-navy">{t.title}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">{t.desc}</p>
            <div class="mt-5 flex items-center gap-2 text-sm font-semibold text-brand-600">
              <Icon name="graduation" class="w-4 h-4" />
              {t.duration}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- IMAGE BANNER -->
  <section class="container-page pb-4">
    <div class="reveal overflow-hidden rounded-3xl ring-1 ring-slate-100 shadow-sm">
      <img
        src={realOrgLearningImage.src}
        alt="Real org based learning — work on live orgs, gain real-world experience"
        loading="lazy"
        class="aspect-[4/3] w-full object-cover"
      />
    </div>
  </section>

  <!-- WHAT YOU GET -->
  <section class="bg-slate-50/70 py-10 sm:py-14">
    <div class="container-page grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <SectionHeading
          align="left"
          eyebrow="What you get"
          title="More than a course — a launchpad"
          subtitle="We focus on real skills, real projects, and real career outcomes."
        />
        <ul class="mt-8 grid sm:grid-cols-2 gap-4">
          {
            trainingFeatures.map((f) => (
              <li class="flex items-start gap-3 text-sm font-medium text-slate-700">
                <span class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-full bg-brand-100 text-brand-700">
                  <Icon name="check" class="w-3.5 h-3.5" />
                </span>
                {f}
              </li>
            ))
          }
        </ul>
      </div>
      <div class="rounded-3xl bg-brand-gradient p-8 sm:p-10 text-white shadow-xl">
        <Icon name="rocket" class="w-10 h-10" />
        <h3 class="mt-5 text-2xl font-extrabold">Freshers welcome</h3>
        <p class="mt-3 text-brand-100/90 leading-relaxed">
          No prior Salesforce experience needed. If you're motivated to learn,
          we'll give you the skills, mentorship, and hands-on projects to launch
          a career in the Salesforce ecosystem.
        </p>
        <div class="mt-6">
          <Button href="/careers" variant="white" icon="arrow">See open internships</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="container-page pt-10 sm:pt-14 pb-10 sm:pb-14">
    <SectionHeading
      eyebrow="How it works"
      title="Your path to a Salesforce career"
    />
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        steps.map((s) => (
          <div class="reveal card-lift relative rounded-2xl bg-white p-6 ring-1 ring-slate-100 shadow-sm hover:ring-brand-200 hover:shadow-lg">
            <span class="text-3xl font-extrabold text-gradient">{s.n}</span>
            <h3 class="mt-3 font-bold text-navy">{s.t}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{s.d}</p>
          </div>
        ))
      }
    </div>
  </section>

  <CTASection
    title="Ready to start your Salesforce journey?"
    subtitle="Get in touch to learn about upcoming batches, fees, and internship opportunities."
    primaryLabel="Enquire about training"
    secondaryLabel="View careers"
    secondaryHref="/careers"
  />
</Layout>
