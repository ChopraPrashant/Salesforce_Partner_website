---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import Button from "../../components/Button.astro";
import Icon from "../../components/Icon.astro";
import CTASection from "../../components/CTASection.astro";
import { services } from "../../data/site";
import agentforceEinsteinAi from "../../Images/Agentforce_Einstein_AI.png";
import congaClm from "../../Images/Conga_CLM.png";
import congaCpq from "../../Images/Conga_CPQ.png";
import experienceCloud from "../../Images/ExperienceCloud.png";
import integrationDataMigration from "../../Images/Integratioin_DataMigration.png";
import managedServices from "../../Images/ManagedServices.png";
import rca from "../../Images/RCA.png";
import salesCloud from "../../Images/SalesCloud.png";
import salesforceLogo from "../../Images/Salesforce_Logo.jpg";
import serviceCloud from "../../Images/ServiceCloud.png";

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

// Related services (same category, excluding current)
const related = services
  .filter((s) => s.category === service.category && s.slug !== service.slug)
  .slice(0, 3);
const relatedFallback =
  related.length > 0
    ? related
    : services.filter((s) => s.slug !== service.slug).slice(0, 3);

const serviceImages: Record<string, { src: string }> = {
  "salesforce-crm": salesforceLogo,
  "sales-cloud": salesCloud,
  "service-cloud": serviceCloud,
  "revenue-cloud-advanced": rca,
  "experience-cloud": experienceCloud,
  "conga-cpq": congaCpq,
  "conga-clm": congaClm,
  "integration-services": integrationDataMigration,
  "agentforce-ai": agentforceEinsteinAi,
  "managed-services": managedServices,
};
const serviceImage = serviceImages[service.slug];
const isLogoOnlyImage = service.slug === "salesforce-crm";
---

<Layout title={service.title} description={service.overview}>
  <PageHero
    eyebrow={service.category}
    title={service.title}
    subtitle={service.overview}
    breadcrumb={[
      { label: "Home", href: "/" },
      { label: "Services", href: "/services" },
      { label: service.title },
    ]}
  >
    <div class="mt-8 flex flex-col sm:flex-row gap-3">
      <Button href="/contact" variant="white" size="lg" icon="arrow">
        Discuss your project
      </Button>
    </div>
  </PageHero>

  <!-- BANNER IMAGE -->
  <section class="container-page -mt-8 relative z-10">
    <div class="group overflow-hidden rounded-3xl ring-1 ring-slate-100 shadow-xl">
      <div class="relative">
        {
          serviceImage && (
            <>
              <div class="absolute inset-0 bg-gradient-to-br from-brand-50 via-white to-accent/10" aria-hidden="true"></div>
              <img
                src={serviceImage.src}
                alt={service.title}
                loading="lazy"
                class={`relative h-56 w-full transition-transform duration-700 group-hover:scale-105 sm:h-72 ${
                  isLogoOnlyImage ? "bg-white/90 object-contain p-10 sm:p-14" : "object-contain p-4 sm:p-6"
                }`}
              />
            </>
          )
        }
        <div class="absolute inset-0 bg-gradient-to-tr from-navy/70 via-navy/25 to-transparent"></div>
      </div>
    </div>
  </section>

  <!-- WHAT'S INCLUDED -->
  <section class="container-page py-10 sm:py-14">
    <div class="grid lg:grid-cols-3 gap-10 lg:gap-14">
      <div class="lg:col-span-2">
        <span class="eyebrow text-sm sm:text-base bg-brand-50 text-brand-700 ring-1 ring-brand-100 mb-3">
          What's included
        </span>
        <h2 class="text-2xl sm:text-3xl font-extrabold text-navy tracking-tight">
          Capabilities we deliver
        </h2>
        <div class="mt-8 grid sm:grid-cols-2 gap-4">
          {
            service.features.map((f) => (
              <div class="flex items-start gap-3 rounded-xl bg-slate-50 p-4 ring-1 ring-slate-100 transition-all duration-200 hover:-translate-y-0.5 hover:bg-brand-50 hover:ring-brand-200">
                <span class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-full bg-brand-100 text-brand-700">
                  <Icon name="check" class="w-3.5 h-3.5" />
                </span>
                <span class="text-sm font-medium text-slate-700">{f}</span>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Outcomes sidebar -->
      <aside class="lg:col-span-1">
        <div class="sticky top-24 rounded-2xl bg-navy-gradient p-7 text-white shadow-lg">
          <span class="grid h-12 w-12 place-items-center rounded-xl bg-white/10">
            <Icon name={service.icon} class="w-6 h-6 text-white" />
          </span>
          <h3 class="mt-5 text-lg font-bold">Business outcomes</h3>
          <ul class="mt-4 space-y-3">
            {
              service.outcomes.map((o) => (
                <li class="flex items-start gap-3 text-sm text-brand-100/90">
                  <Icon name="check" class="mt-0.5 w-4 h-4 shrink-0 text-accent-light" />
                  {o}
                </li>
              ))
            }
          </ul>
          <div class="mt-6 border-t border-white/15 pt-5">
            <Button href="/contact" variant="white" class="w-full" icon="arrow">
              Get started
            </Button>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-slate-50/70 py-10 sm:py-14">
    <div class="container-page">
      <h2 class="text-2xl font-extrabold text-navy tracking-tight">Related services</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          relatedFallback.map((s) => (
            <a
              href={`/services/${s.slug}`}
              class="card-lift group rounded-2xl bg-white p-6 ring-1 ring-slate-100 shadow-sm hover:ring-brand-200"
            >
              <span class="grid h-11 w-11 place-items-center rounded-xl bg-brand-50 text-brand-600 group-hover:bg-brand-gradient group-hover:text-white transition-colors">
                <Icon name={s.icon} class="w-5 h-5" />
              </span>
              <h3 class="mt-4 font-bold text-navy">{s.title}</h3>
              <p class="mt-2 text-sm text-slate-600 line-clamp-2">{s.short}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <CTASection />
</Layout>
