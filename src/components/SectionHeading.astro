---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: "center" | "left";
  variant?: "dark" | "light";
  class?: string;
}
const {
  eyebrow,
  title,
  subtitle,
  align = "center",
  variant = "dark",
  class: className = "",
} = Astro.props;

const alignCls = align === "center" ? "text-center mx-auto items-center" : "text-left items-start";
const titleColor = variant === "light" ? "text-white" : "text-navy";
const subColor = variant === "light" ? "text-brand-100/80" : "text-slate-600";
const eyebrowCls =
  variant === "light"
    ? "bg-white/10 text-brand-100 ring-1 ring-white/15"
    : "bg-brand-50 text-brand-700 ring-1 ring-brand-100";
---

<div class={`flex flex-col max-w-2xl ${alignCls} ${className}`}>
  {
    eyebrow && (
      <span class={`eyebrow text-base sm:text-lg lg:text-xl mb-5 ${eyebrowCls}`}>
        <span class="h-2 w-2 rounded-full bg-flare" />
        {eyebrow}
      </span>
    )
  }
  <h2 class={`text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight ${titleColor}`}>
    {title}
  </h2>
  {
    subtitle && (
      <p class={`mt-4 text-base sm:text-lg leading-relaxed ${subColor}`}>
        {subtitle}
      </p>
    )
  }
</div>
