---
import Logo from "./Logo.astro";
import Button from "./Button.astro";
import Icon from "./Icon.astro";
import { navItems, services } from "../data/site";

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header
  id="site-header"
  class="fixed top-0 inset-x-0 z-50 transition-[background-color,border-color,box-shadow] duration-300 border-b border-transparent"
>
  <div class="container-page">
    <nav class="flex items-center justify-between h-16 lg:h-20" aria-label="Primary">
      <Logo />

      <!-- Desktop nav -->
      <ul class="hidden lg:flex items-center gap-1.5 rounded-full bg-slate-50/90 p-1.5 ring-1 ring-slate-100">
        {
          navItems.map((item) =>
            item.label === "Services" ? (
              <li class="relative group">
                <a
                  href={item.href}
                  class={`nav-pill flex items-center gap-1 px-4 py-2 rounded-full text-sm font-semibold ${
                    isActive(item.href)
                      ? "bg-brand-gradient text-white shadow-md shadow-brand-600/30"
                      : "text-slate-700 hover:bg-white hover:text-brand-700 hover:shadow-sm hover:ring-1 hover:ring-slate-100"
                  }`}
                >
                  {item.label}
                  <Icon name="arrow" class="w-3.5 h-3.5 rotate-90 opacity-60" />
                </a>
                <div class="absolute left-1/2 -translate-x-1/2 top-full pt-3 w-[34rem] opacity-0 invisible translate-y-1 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 transition-all duration-200">
                  <div class="rounded-2xl bg-white shadow-2xl ring-1 ring-slate-100 p-3 grid grid-cols-2 gap-1">
                    {services.map((s) => (
                      <a
                        href={`/services/${s.slug}`}
                        class="flex items-start gap-3 rounded-xl p-3 hover:bg-brand-50 transition-colors"
                      >
                        <span class="mt-0.5 grid place-items-center h-8 w-8 shrink-0 rounded-lg bg-brand-50 text-brand-600">
                          <Icon name={s.icon} class="w-4 h-4" />
                        </span>
                        <span>
                          <span class="block text-sm font-semibold text-navy">
                            {s.title}
                          </span>
                          <span class="block text-xs text-slate-500 line-clamp-1">
                            {s.short}
                          </span>
                        </span>
                      </a>
                    ))}
                    <a
                      href="/services"
                      class="col-span-2 mt-1 flex items-center justify-center gap-2 rounded-xl bg-navy px-3 py-2.5 text-sm font-semibold text-white hover:bg-navy-light transition-colors"
                    >
                      View all services
                      <Icon name="arrow" class="w-4 h-4" />
                    </a>
                  </div>
                </div>
              </li>
            ) : (
              <li>
                <a
                  href={item.href}
                  class={`nav-pill block px-4 py-2 rounded-full text-sm font-semibold ${
                    isActive(item.href)
                      ? "bg-brand-gradient text-white shadow-md shadow-brand-600/30"
                      : "text-slate-700 hover:bg-white hover:text-brand-700 hover:shadow-sm hover:ring-1 hover:ring-slate-100"
                  }`}
                >
                  {item.label}
                </a>
              </li>
            )
          )
        }
      </ul>

      <div class="hidden lg:block">
        <Button href="/contact" size="sm" icon="arrow">Contact Us</Button>
      </div>

      <!-- Mobile toggle -->
      <button
        id="menu-toggle"
        class="lg:hidden grid place-items-center h-10 w-10 rounded-lg text-navy hover:bg-slate-100"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-open" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg id="icon-close" class="w-6 h-6 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M6 18L18 6"/></svg>
      </button>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden bg-white border-t border-slate-100 shadow-xl"
  >
    <div class="container-page py-4 max-h-[80vh] overflow-y-auto">
      <ul class="space-y-1">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class={`block px-3 py-3 rounded-lg text-base font-semibold ${
                  isActive(item.href)
                    ? "bg-brand-50 text-brand-700"
                    : "text-slate-800 hover:bg-slate-50"
                }`}
              >
                {item.label}
              </a>
              {item.label === "Services" && (
                <ul class="ml-3 mt-1 mb-2 space-y-0.5 border-l border-slate-100 pl-3">
                  {services.map((s) => (
                    <li>
                      <a
                        href={`/services/${s.slug}`}
                        class="block px-3 py-2 rounded-lg text-sm text-slate-600 hover:bg-slate-50 hover:text-brand-700"
                      >
                        {s.title}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))
        }
      </ul>
      <div class="mt-4">
        <Button href="/contact" class="w-full" icon="arrow">Contact Us</Button>
      </div>
    </div>
  </div>
</header>
<!-- Spacer so fixed header doesn't overlap content -->
<div class="h-16 lg:h-20"></div>

<script>
  const header = document.getElementById("site-header");
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");

  let isScrolled = false;
  let ticking = false;

  const updateHeader = () => {
    if (!header) return;
    const shouldBeScrolled = window.scrollY > 8;
    if (shouldBeScrolled === isScrolled) return;

    isScrolled = shouldBeScrolled;
    if (isScrolled) {
      header.classList.add("bg-white/95", "shadow-sm");
      header.classList.remove("border-transparent");
      header.classList.add("border-slate-100");
    } else {
      header.classList.remove("bg-white/95", "shadow-sm", "border-slate-100");
      header.classList.add("border-transparent");
    }
  };

  const onScroll = () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      updateHeader();
      ticking = false;
    });
  };

  updateHeader();
  window.addEventListener("scroll", onScroll, { passive: true });

  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
    iconOpen?.classList.toggle("hidden", open);
    iconClose?.classList.toggle("hidden", !open);
    document.body.style.overflow = open ? "hidden" : "";
  });
</script>
