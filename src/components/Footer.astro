---
import Logo from "./Logo.astro";
import Icon from "./Icon.astro";
import { company, services } from "../data/site";

const year = new Date().getFullYear();
const topServices = services.slice(0, 6);

const companyLinks = [
  { label: "About Us", href: "/about" },
  { label: "Projects Delivered", href: "/projects" },
  { label: "Training & Internships", href: "/training" },
  { label: "Careers", href: "/careers" },
  { label: "Contact", href: "/contact" },
];
---

<footer class="bg-navy-gradient text-white">
  <div class="container-page pt-16 pb-8">
    <div class="grid gap-12 lg:grid-cols-12">
      <!-- Brand -->
      <div class="lg:col-span-4">
        <Logo variant="light" />
        <p class="mt-5 text-sm leading-relaxed text-brand-100/75 max-w-sm">
          {company.description}
        </p>
        <div class="mt-6 flex items-center gap-3">
          {
            company.socials.map((s) => (
              <a
                href={s.href}
                aria-label={s.label}
                class="grid place-items-center h-10 w-10 rounded-full bg-white/10 hover:bg-white/20 transition-colors"
              >
                <Icon name={s.icon} class="w-5 h-5" />
              </a>
            ))
          }
        </div>
      </div>

      <!-- Services -->
      <div class="lg:col-span-3">
        <h3 class="text-base font-bold tracking-tight text-white">Services</h3>
        <ul class="mt-5 space-y-3">
          {
            topServices.map((s) => (
              <li>
                <a
                  href={`/services/${s.slug}`}
                  class="text-sm text-brand-100/75 hover:text-white transition-colors"
                >
                  {s.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Company -->
      <div class="lg:col-span-2">
        <h3 class="text-base font-bold tracking-tight text-white">Company</h3>
        <ul class="mt-5 space-y-3">
          {
            companyLinks.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="text-sm text-brand-100/75 hover:text-white transition-colors"
                >
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact -->
      <div class="lg:col-span-3">
        <h3 class="text-base font-bold tracking-tight text-white">Get in touch</h3>
        <ul class="mt-5 space-y-4 text-sm text-brand-100/75">
          <li class="flex items-start gap-3">
            <Icon name="pin" class="w-5 h-5 shrink-0 text-brand-300" />
            <span>{company.address.full}</span>
          </li>
          <li class="flex items-center gap-3">
            <Icon name="mail" class="w-5 h-5 shrink-0 text-brand-300" />
            <a href={`mailto:${company.email}`} class="hover:text-white transition-colors">{company.email}</a>
          </li>
          <li class="flex items-center gap-3">
            <Icon name="phone" class="w-5 h-5 shrink-0 text-brand-300" />
            <a href={`tel:${company.phone.replace(/\s/g, "")}`} class="hover:text-white transition-colors">{company.phone}</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-14 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-brand-100/60 text-center sm:text-left">
        © {year} {company.name}. All rights reserved.
      </p>
      <div class="flex items-center gap-6 text-xs text-brand-100/60">
        <a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/terms" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
