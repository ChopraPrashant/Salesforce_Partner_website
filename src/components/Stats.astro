---
import Icon from "./Icon.astro";
import { stats } from "../data/site";

interface Props {
  variant?: "dark" | "light";
}
const { variant = "light" } = Astro.props;

const cardCls =
  variant === "dark"
    ? "glass"
    : "bg-white ring-1 ring-slate-100 shadow-sm hover:ring-brand-200 hover:shadow-xl";
const valueColor = variant === "dark" ? "text-white" : "text-navy";
const labelColor = variant === "dark" ? "text-brand-100" : "text-navy";
const hintColor = variant === "dark" ? "text-brand-100/70" : "text-slate-500";
const iconWrap =
  variant === "dark"
    ? "bg-white/10 text-white"
    : "bg-brand-50 text-brand-600 group-hover:bg-brand-gradient group-hover:text-white";
---

<div class="grid grid-cols-2 lg:grid-cols-4 gap-5 sm:gap-6">
  {
    stats.map((s) => (
      <div class={`card-lift group relative overflow-hidden rounded-2xl p-6 ${cardCls}`}>
        <span class={`grid h-12 w-12 place-items-center rounded-xl transition-colors ${iconWrap}`}>
          <Icon name={s.icon} class="w-6 h-6" />
        </span>
        <div class={`mt-5 text-4xl sm:text-5xl font-extrabold tracking-tight ${valueColor}`}>
          <span class="text-gradient">{s.value}</span>
        </div>
        <div class={`mt-1.5 text-sm font-bold ${labelColor}`}>{s.label}</div>
        <p class={`mt-2 text-xs leading-relaxed ${hintColor}`}>{s.hint}</p>
      </div>
    ))
  }
</div>
